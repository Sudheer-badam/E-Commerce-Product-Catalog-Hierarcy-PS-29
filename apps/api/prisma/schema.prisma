generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id             String      @id @default(cuid())
  name           String
  price          Float
  image          String
  category       String
  description    String?
  stock          Int         @default(0)
  kind           ProductKind
  weight         String?
  deliveryCharge Float?
  licenseKey     String?
  downloadUrl    String?
  renewalPeriod  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Order {
  id                   String   @id @default(cuid())
  customerId           String
  items                Json
  totalAmount          Float
  paymentStatus        String   @default("Pending")
  orderStatus          String   @default("Pending")
  paymentScreenshotUrl String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  sender    String
  text      String
  room      String   @default("support_room")
  createdAt DateTime @default(now())
}

enum ProductKind {
  PHYSICAL
  DIGITAL
  SUBSCRIPTION
}
