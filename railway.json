{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && cd apps/api && npx prisma generate && npx nest build"
  },
  "deploy": {
    "startCommand": "node apps/api/dist/main.js",
    "restartPolicyType": "ON_FAILURE"
  }
}
